# Claude Daemon environment variables
# Copy this to .env and fill in your values

# Telegram Bot (get from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=bot123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Discord Bot (get from Discord Developer Portal)
# DISCORD_BOT_TOKEN=MTIzNDU2Nzg5MDEyMzQ1Njc4OQ.AbCdEf.GhIjKlMnOpQrStUvWxYz

# Paperclip (multi-agent orchestration)
# PAPERCLIP_URL=https://paperclip.example.com/api
# PAPERCLIP_API_KEY=pk_live_...

# HTTP API authentication
# CLAUDE_DAEMON_API_KEY=your-secret-api-key

# MCP Server credentials (used in agent tools.json)
# GITHUB_TOKEN=ghp_...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T...
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your-project-ref

# Optional overrides
# CLAUDE_DAEMON_LOG_LEVEL=DEBUG
# CLAUDE_DAEMON_DATA_DIR=/custom/path/to/data
