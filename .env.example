# Claude Daemon environment variables
# Copy this to .env and fill in your values

# Telegram Bot (get from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=bot123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Discord Bot (get from Discord Developer Portal)
# DISCORD_BOT_TOKEN=MTIzNDU2Nzg5MDEyMzQ1Njc4OQ.AbCdEf.GhIjKlMnOpQrStUvWxYz

# Paperclip (multi-agent orchestration)
# PAPERCLIP_URL=https://paperclip.example.com/api
# PAPERCLIP_API_KEY=pk_live_...

# HTTP API authentication
# CLAUDE_DAEMON_API_KEY=your-secret-api-key

# Webhook secrets
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# STRIPE_WEBHOOK_SECRET=whsec_...

# -- MCP Server Credentials --
# Servers auto-enable when their env vars are set.
# Zero-config servers (fetch, git, time, etc.) need no tokens.

# Existing integrations
# GITHUB_TOKEN=ghp_...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T...
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your-project-ref
# GMAIL_OAUTH_CREDENTIALS=...
# GCAL_OAUTH_CREDENTIALS=...

# Search & Web
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=BSA...
# FIRECRAWL_API_KEY=fc-...

# Data
# POSTGRES_URL=postgresql://user:pass@host:5432/db
# MONGODB_URI=mongodb://host:27017/db

# Developer
# SENTRY_AUTH_TOKEN=sntrys_...

# Productivity
# GDRIVE_OAUTH_CREDENTIALS=...
# NOTION_API_KEY=ntn_...
# LINEAR_API_KEY=lin_api_...
# OBSIDIAN_VAULT_PATH=/path/to/vault

# Analytics
# SNOWFLAKE_ACCOUNT=xy12345.us-east-1
# SNOWFLAKE_USER=myuser
# SNOWFLAKE_PASSWORD=...
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# AI & Models
# ELEVENLABS_API_KEY=...
# HF_TOKEN=hf_...
# REPLICATE_API_TOKEN=r8_...

# Infrastructure
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# VERCEL_TOKEN=...

# Optional overrides
# CLAUDE_DAEMON_LOG_LEVEL=DEBUG
# CLAUDE_DAEMON_DATA_DIR=/custom/path/to/data
